# ============================================================
# KickCast Configuration — copy to .env and fill in values
# ============================================================

# === Football API (football-data.org v4) ===
# Register free at: https://www.football-data.org/client/register
FOOTBALL_API_BASE_URL=https://api.football-data.org/v4
FOOTBALL_API_KEY=your_api_key_here
FOOTBALL_API_COMPETITION=WC
FOOTBALL_API_POLL_INTERVAL_SECONDS=300

# === Historical Data ===
# Path to the Kaggle CSV (martj42/international-football-results)
# Download from: https://www.kaggle.com/datasets/martj42/international-football-results-from-1872-to-2017
HISTORICAL_DATA_PATH=./data/raw/results.csv

# === Azure Storage ===
# Default: Azurite local emulator. Replace with real connection string for Azure deployment.
AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=http;AccountName=devstoreaccount1;AccountKey=Eby8vdM02xNOcqFlqUwJPLlmEtlCDXJ1OUzFT50uSRZ6IFsuFq2UVErCz4I6tq/K1SZFPTOtr/KBHBeksoGMGw==;BlobEndpoint=http://127.0.0.1:10000/devstoreaccount1;TableEndpoint=http://127.0.0.1:10002/devstoreaccount1;QueueEndpoint=http://127.0.0.1:10001/devstoreaccount1;

# === Storage Container / Table Names ===
BLOB_CONTAINER_RAW=kickcast-raw
BLOB_CONTAINER_PROCESSED=kickcast-processed
TABLE_FIXTURES=fixtures
TABLE_PREDICTIONS=predictions
TABLE_ACCURACY=accuracy
